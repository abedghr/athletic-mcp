# Keep the Docker build context lean and prevent secrets from leaking in
.git
.github
.venv
venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache
.ruff_cache

# Logs / local data
logs/
*.log
.athlete/
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm

# Local config + secrets — must NEVER end up in image
.env
.env.*
!.env.example

# IDE / OS junk
.vscode
.idea
.DS_Store
*.swp

# Build artifacts
dist/
build/
*.egg-info
.eggs/

# Docs / project files not needed at runtime
README.md
CLAUDE_SYSTEM_PROMPT.md
claude_desktop_config_snippet.json
