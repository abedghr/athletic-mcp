# Local development uses local SQLite at this path:
ATHLETE_DB_PATH=/Users/yourname/.athlete/training.db

# === Cloud database (Turso) ===
# When TURSO_DATABASE_URL is set, it OVERRIDES ATHLETE_DB_PATH.
# Get these from https://turso.tech dashboard.
# Use libsql:// scheme — the code auto-converts to https:// at runtime.
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-token-here

# === API config ===
ATHLETE_API_HOST=0.0.0.0
ATHLETE_API_PORT=8000
ATHLETE_API_BASE_URL=http://localhost:8000

# === Authentication ===
# Required for any deployment exposed to the public internet.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Leave blank for local-only dev (auth will be disabled).
# MCP_API_KEY=

# === Athlete profile ===
DEFAULT_BODYWEIGHT_KG=80.0
ATHLETE_NAME=YourName

# === Logging ===
LOG_LEVEL=INFO

# === Local dev flag ===
# Set to 1 to enable uvicorn auto-reload (don't set in production)
ATHLETE_DEV=1
